<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="orcamento"
              pageWidth="595" pageHeight="842"
              leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              whenNoDataType="NoDataSection">

    <parameter name="EMPRESA_NOME"      class="java.lang.String"/>
    <parameter name="EMPRESA_CNPJ"      class="java.lang.String"/>
    <parameter name="EMPRESA_TELEFONE"  class="java.lang.String"/>
    <parameter name="EMPRESA_EMAIL"     class="java.lang.String"/>
    <parameter name="ORC_NUMERO"        class="java.lang.String"/>
    <parameter name="ORC_DATA_EMISSAO"  class="java.lang.String"/>
    <parameter name="ORC_DATA_VALIDADE" class="java.lang.String"/>
    <parameter name="CLIENTE_NOME"      class="java.lang.String"/>
    <parameter name="CLIENTE_CPFCNPJ"   class="java.lang.String"/>
    <parameter name="CLIENTE_ENDERECO"  class="java.lang.String"/>
    <parameter name="VENDEDOR_NOME"     class="java.lang.String"/>
    <parameter name="ORC_OBSERVACOES"   class="java.lang.String"/>
    <parameter name="ORC_SUBTOTAL"      class="java.math.BigDecimal"/>
    <parameter name="ORC_DESCONTO"      class="java.math.BigDecimal"/>
    <parameter name="ORC_TOTAL"         class="java.math.BigDecimal"/>

    <field name="ordem"         class="java.lang.Integer"/>
    <field name="descricao"     class="java.lang.String"/>
    <field name="quantidade"    class="java.math.BigDecimal"/>
    <field name="unidade"       class="java.lang.String"/>
    <field name="precoUnitario" class="java.math.BigDecimal"/>
    <field name="desconto"      class="java.math.BigDecimal"/>
    <field name="total"         class="java.math.BigDecimal"/>

    <title>
        <band height="175" splitType="Stretch">

            <textField isBlankWhenNull="true">
                <reportElement x="0" y="0" width="350" height="22"/>
                <textElement>
                    <font size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{EMPRESA_NOME}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="0" y="24" width="350" height="14"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["CNPJ: " + ($P{EMPRESA_CNPJ} != null ? $P{EMPRESA_CNPJ} : "")]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="0" y="40" width="350" height="14"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[($P{EMPRESA_TELEFONE} != null ? $P{EMPRESA_TELEFONE} : "") + "  |  " + ($P{EMPRESA_EMAIL} != null ? $P{EMPRESA_EMAIL} : "")]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="350" y="0" width="185" height="28"/>
                <textElement textAlignment="Right">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[ORÇAMENTO]]></text>
            </staticText>

            <textField isBlankWhenNull="true">
                <reportElement x="350" y="30" width="185" height="16"/>
                <textElement textAlignment="Right">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ORC_NUMERO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="350" y="48" width="90" height="14"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Emissão:]]></text>
            </staticText>

            <textField isBlankWhenNull="true">
                <reportElement x="442" y="48" width="93" height="14"/>
                <textElement textAlignment="Right">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ORC_DATA_EMISSAO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="350" y="64" width="90" height="14"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Válido até:]]></text>
            </staticText>

            <textField isBlankWhenNull="true">
                <reportElement x="442" y="64" width="93" height="14" forecolor="#C9184A"/>
                <textElement textAlignment="Right">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ORC_DATA_VALIDADE}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="92" width="535" height="1"/>
                <graphicElement>
                    <pen lineWidth="1.5" lineColor="#1a2744"/>
                </graphicElement>
            </line>

            <staticText>
                <reportElement x="0" y="100" width="80" height="14"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[CLIENTE:]]></text>
            </staticText>

            <textField isBlankWhenNull="true">
                <reportElement x="80" y="100" width="455" height="14"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CLIENTE_NOME}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="116" width="80" height="14"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[CPF/CNPJ:]]></text>
            </staticText>

            <textField isBlankWhenNull="true">
                <reportElement x="80" y="116" width="200" height="14"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CLIENTE_CPFCNPJ}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="310" y="116" width="70" height="14"/>
                <textElement textAlignment="Right">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Vendedor:]]></text>
            </staticText>

            <textField isBlankWhenNull="true">
                <reportElement x="385" y="116" width="150" height="14"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{VENDEDOR_NOME}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="132" width="80" height="14"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Endereço:]]></text>
            </staticText>

            <textField isBlankWhenNull="true">
                <reportElement x="80" y="132" width="455" height="14"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CLIENTE_ENDERECO}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="154" width="535" height="1"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#888888"/>
                </graphicElement>
            </line>

        </band>
    </title>

    <columnHeader>
        <band height="20" splitType="Stretch">

            <rectangle>
                <reportElement x="0" y="0" width="535" height="20" backcolor="#1a2744" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="4" y="3" width="26" height="14" forecolor="#FFFFFF"/>
                <textElement>
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[#]]></text>
            </staticText>

            <staticText>
                <reportElement x="32" y="3" width="195" height="14" forecolor="#FFFFFF"/>
                <textElement>
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[DESCRIÇÃO]]></text>
            </staticText>

            <staticText>
                <reportElement x="230" y="3" width="45" height="14" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[QTD]]></text>
            </staticText>

            <staticText>
                <reportElement x="278" y="3" width="40" height="14" forecolor="#FFFFFF"/>
                <textElement>
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[UN]]></text>
            </staticText>

            <staticText>
                <reportElement x="320" y="3" width="80" height="14" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[PREÇO UNIT.]]></text>
            </staticText>

            <staticText>
                <reportElement x="402" y="3" width="60" height="14" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[DESCONTO]]></text>
            </staticText>

            <staticText>
                <reportElement x="464" y="3" width="67" height="14" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL]]></text>
            </staticText>

        </band>
    </columnHeader>

    <detail>
        <band height="18" splitType="Stretch">

            <textField isBlankWhenNull="true">
                <reportElement x="4" y="2" width="26" height="14"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{ordem}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="32" y="2" width="195" height="14"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{descricao}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true" pattern="#,##0.####">
                <reportElement x="230" y="2" width="45" height="14"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{quantidade}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="278" y="2" width="40" height="14"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{unidade}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true" pattern="#,##0.00">
                <reportElement x="320" y="2" width="80" height="14"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{precoUnitario}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true" pattern="#,##0.00">
                <reportElement x="402" y="2" width="60" height="14"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{desconto}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true" pattern="#,##0.00">
                <reportElement x="464" y="2" width="67" height="14"/>
                <textElement textAlignment="Right">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{total}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="17" width="535" height="1"/>
                <graphicElement>
                    <pen lineWidth="0.3" lineColor="#DDDDDD"/>
                </graphicElement>
            </line>

        </band>
    </detail>

    <summary>
        <band height="160" splitType="Stretch">

            <line>
                <reportElement x="0" y="8" width="535" height="1"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#1a2744"/>
                </graphicElement>
            </line>

            <staticText>
                <reportElement x="350" y="16" width="110" height="14"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Subtotal:]]></text>
            </staticText>

            <textField isBlankWhenNull="true" pattern="#,##0.00">
                <reportElement x="464" y="16" width="67" height="14"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ORC_SUBTOTAL}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="350" y="32" width="110" height="14"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Desconto:]]></text>
            </staticText>

            <textField isBlankWhenNull="true" pattern="#,##0.00">
                <reportElement x="464" y="32" width="67" height="14"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ORC_DESCONTO}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="348" y="48" width="185" height="24" backcolor="#1a2744" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="352" y="52" width="106" height="16" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right">
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[VALOR TOTAL:]]></text>
            </staticText>

            <textField isBlankWhenNull="true" pattern="#,##0.00">
                <reportElement x="460" y="52" width="69" height="16" forecolor="#c9a84c"/>
                <textElement textAlignment="Right">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ORC_TOTAL}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true" isStretchWithOverflow="true">
                <reportElement x="0" y="82" width="340" height="40"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[($P{ORC_OBSERVACOES} != null && !$P{ORC_OBSERVACOES}.isEmpty()) ? "Observações: " + $P{ORC_OBSERVACOES} : ""]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="0" y="126" width="535" height="14"/>
                <textElement textAlignment="Center">
                    <font size="9" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Este orçamento é válido até " + ($P{ORC_DATA_VALIDADE} != null ? $P{ORC_DATA_VALIDADE} : "")]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="100" y="144" width="180" height="1"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </line>

            <staticText>
                <reportElement x="100" y="147" width="180" height="12"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Assinatura do Cliente]]></text>
            </staticText>

            <staticText>
                <reportElement x="320" y="144" width="215" height="12"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Aprovado em: ____/____/______]]></text>
            </staticText>

        </band>
    </summary>

    <noData>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="535" height="20"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <text><![CDATA[Nenhum item no orçamento.]]></text>
            </staticText>
        </band>
    </noData>

</jasperReport>
