<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="relatorio-financeiro" pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20">
    <parameter name="EMPRESA_NOME" class="java.lang.String"/>
    <parameter name="EMPRESA_CNPJ" class="java.lang.String"/>
    <parameter name="EMPRESA_LOGOTIPO" class="java.awt.Image"/>
    <parameter name="TITULO" class="java.lang.String"/>
    <parameter name="PERIODO" class="java.lang.String"/>
    <parameter name="FILTROS" class="java.lang.String"/>
    <parameter name="DATA_GERACAO" class="java.lang.String"/>
    <parameter name="TOTAL_1_LABEL" class="java.lang.String"/>
    <parameter name="TOTAL_1" class="java.lang.String"/>
    <parameter name="TOTAL_2_LABEL" class="java.lang.String"/>
    <parameter name="TOTAL_2" class="java.lang.String"/>
    <parameter name="TOTAL_3_LABEL" class="java.lang.String"/>
    <parameter name="TOTAL_3" class="java.lang.String"/>
    <parameter name="TOTAL_4_LABEL" class="java.lang.String"/>
    <parameter name="TOTAL_4" class="java.lang.String"/>
    <field name="secao" class="java.lang.String"/>
    <field name="pessoa" class="java.lang.String"/>
    <field name="descricao" class="java.lang.String"/>
    <field name="parcela" class="java.lang.String"/>
    <field name="vencimento" class="java.lang.String"/>
    <field name="valor" class="java.lang.String"/>
    <field name="pago" class="java.lang.String"/>
    <field name="forma" class="java.lang.String"/>
    <field name="status" class="java.lang.String"/>
    <title>
        <band height="96">
            <image><reportElement x="0" y="0" width="70" height="42"><printWhenExpression><![CDATA[$P{EMPRESA_LOGOTIPO} != null]]></printWhenExpression></reportElement><imageExpression><![CDATA[$P{EMPRESA_LOGOTIPO}]]></imageExpression></image>
            <textField><reportElement x="80" y="0" width="420" height="18"/><textElement><font size="13" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{EMPRESA_NOME}]]></textFieldExpression></textField>
            <textField><reportElement x="80" y="20" width="420" height="14"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA["CNPJ: " + $P{EMPRESA_CNPJ}]]></textFieldExpression></textField>
            <textField><reportElement x="520" y="0" width="262" height="22"/><textElement textAlignment="Right"><font size="16" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{TITULO}]]></textFieldExpression></textField>
            <textField><reportElement x="520" y="24" width="262" height="14"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA["Gerado em: " + $P{DATA_GERACAO}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="50" width="380" height="14"/><textElement><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{PERIODO}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="66" width="782" height="14"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$P{FILTROS}]]></textFieldExpression></textField>
            <line><reportElement x="0" y="88" width="782" height="1"/></line>
        </band>
    </title>
    <columnHeader><band height="18"><rectangle><reportElement x="0" y="0" width="782" height="18" backcolor="#1a2744" mode="Opaque"/></rectangle>
        <staticText><reportElement x="4" y="3" width="95" height="12" forecolor="#FFFFFF"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[SEÇÃO]]></text></staticText>
        <staticText><reportElement x="102" y="3" width="145" height="12" forecolor="#FFFFFF"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[PESSOA]]></text></staticText>
        <staticText><reportElement x="250" y="3" width="180" height="12" forecolor="#FFFFFF"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[DESCRIÇÃO]]></text></staticText>
        <staticText><reportElement x="433" y="3" width="45" height="12" forecolor="#FFFFFF"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[PARC.]]></text></staticText>
        <staticText><reportElement x="481" y="3" width="65" height="12" forecolor="#FFFFFF"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[VENC.]]></text></staticText>
        <staticText><reportElement x="549" y="3" width="70" height="12" forecolor="#FFFFFF"/><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><text><![CDATA[VALOR]]></text></staticText>
        <staticText><reportElement x="622" y="3" width="70" height="12" forecolor="#FFFFFF"/><textElement textAlignment="Right"><font size="8" isBold="true"/></textElement><text><![CDATA[PAGO]]></text></staticText>
        <staticText><reportElement x="695" y="3" width="45" height="12" forecolor="#FFFFFF"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[FORMA]]></text></staticText>
        <staticText><reportElement x="743" y="3" width="39" height="12" forecolor="#FFFFFF"/><textElement><font size="8" isBold="true"/></textElement><text><![CDATA[STATUS]]></text></staticText>
    </band></columnHeader>
    <detail><band height="16">
        <textField><reportElement x="4" y="2" width="95" height="12"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{secao}]]></textFieldExpression></textField>
        <textField><reportElement x="102" y="2" width="145" height="12"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{pessoa}]]></textFieldExpression></textField>
        <textField><reportElement x="250" y="2" width="180" height="12"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{descricao}]]></textFieldExpression></textField>
        <textField><reportElement x="433" y="2" width="45" height="12"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{parcela}]]></textFieldExpression></textField>
        <textField><reportElement x="481" y="2" width="65" height="12"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{vencimento}]]></textFieldExpression></textField>
        <textField><reportElement x="549" y="2" width="70" height="12"/><textElement textAlignment="Right"><font size="7"/></textElement><textFieldExpression><![CDATA[$F{valor}]]></textFieldExpression></textField>
        <textField><reportElement x="622" y="2" width="70" height="12"/><textElement textAlignment="Right"><font size="7"/></textElement><textFieldExpression><![CDATA[$F{pago}]]></textFieldExpression></textField>
        <textField><reportElement x="695" y="2" width="45" height="12"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{forma}]]></textFieldExpression></textField>
        <textField><reportElement x="743" y="2" width="39" height="12"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{status}]]></textFieldExpression></textField>
    </band></detail>
    <pageFooter><band height="18"><textField><reportElement x="690" y="2" width="92" height="12"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression></textField></band></pageFooter>
    <summary><band height="36"><line><reportElement x="0" y="4" width="782" height="1"/></line>
        <textField><reportElement x="0" y="12" width="190" height="14"/><textElement><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{TOTAL_1_LABEL} + ": " + $P{TOTAL_1}]]></textFieldExpression></textField>
        <textField><reportElement x="195" y="12" width="190" height="14"/><textElement><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{TOTAL_2_LABEL} + ": " + $P{TOTAL_2}]]></textFieldExpression></textField>
        <textField><reportElement x="390" y="12" width="190" height="14"/><textElement><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{TOTAL_3_LABEL} + ": " + $P{TOTAL_3}]]></textFieldExpression></textField>
        <textField><reportElement x="585" y="12" width="197" height="14"/><textElement><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{TOTAL_4_LABEL} + ": " + $P{TOTAL_4}]]></textFieldExpression></textField>
    </band></summary>
</jasperReport>
