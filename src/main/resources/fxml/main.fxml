<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.erp.controller.MainController"
            prefWidth="1280" prefHeight="800">

    <!-- Topbar com logo -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
            <!-- Logo carregado via SvgImageLoader no MainController (JavaFX não suporta SVG nativo) -->
            <ImageView fx:id="imgLogoTopbar" fitWidth="130" fitHeight="34" preserveRatio="true" onMouseClicked="#irParaDashboard"/>
            <Region styleClass="topbar-divider" prefWidth="1" prefHeight="20"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblDataHora" styleClass="topbar-usuario"/>
            <Button fx:id="btnTema" onAction="#toggleTema" styleClass="btn-topbar" text="☀"/>
            <Button text="Sair" onAction="#sair" styleClass="btn-topbar"/>
        </HBox>
    </top>

    <!-- Sidebar + Conteúdo -->
    <center>
        <SplitPane dividerPositions="0.165" styleClass="main-split">

            <!-- Sidebar -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="sidebar-scroll">
                <VBox styleClass="sidebar" spacing="0">

                    <Label fx:id="lblSecaoCadastros" text="CADASTROS" styleClass="sidebar-section"/>
                    <Button fx:id="btnClientes" text="Clientes" onAction="#abrirClientes" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2a-account-group" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>
                    <Button fx:id="btnFornecedores" text="Fornecedores" onAction="#abrirFornecedores" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2t-truck-delivery" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>
                    <Button fx:id="btnProdutos" text="Produtos" onAction="#abrirProdutos" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2p-package-variant" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>
                    <Button fx:id="btnFuncionarios" text="Funcionários" onAction="#abrirFuncionarios" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2a-account-tie" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>

                    <Region fx:id="separadorCadastros" styleClass="sidebar-divider" prefHeight="1" maxWidth="Infinity"/>

                    <Label fx:id="lblSecaoEstoque" text="ESTOQUE" styleClass="sidebar-section"/>
                    <Button fx:id="btnEstoque" text="Movimentações" onAction="#abrirEstoque" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2s-swap-vertical" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>
                    <Button fx:id="btnCompras" text="Compras" onAction="#abrirCompras" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2c-cart-arrow-down" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>

                    <Region fx:id="separadorEstoque" styleClass="sidebar-divider" prefHeight="1" maxWidth="Infinity"/>

                    <Label fx:id="lblSecaoComercial" text="COMERCIAL" styleClass="sidebar-section"/>
                    <Button fx:id="btnOrcamentos" text="Orçamentos" onAction="#abrirOrcamentos" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2f-file-document-edit" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>
                    <Button fx:id="btnVendas" text="Vendas" onAction="#abrirVendas" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2p-point-of-sale" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>

                    <Region fx:id="separadorComercial" styleClass="sidebar-divider" prefHeight="1" maxWidth="Infinity"/>

                    <Label fx:id="lblSecaoFinanceiro" text="FINANCEIRO" styleClass="sidebar-section"/>
                    <Button fx:id="btnCaixa" text="Caixa" onAction="#abrirCaixa" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2c-cash-register" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>
                    <Button fx:id="btnContasPagar" text="Contas a Pagar" onAction="#abrirContasPagar" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2c-credit-card-minus" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>
                    <Button fx:id="btnContasReceber" text="Contas a Receber" onAction="#abrirContasReceber" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2c-credit-card-plus" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>

                    <Region fx:id="separadorFinanceiro" styleClass="sidebar-divider" prefHeight="1" maxWidth="Infinity"/>

                    <Label fx:id="lblSecaoRelatorios" text="RELATÓRIOS" styleClass="sidebar-section"/>
                    <Button fx:id="btnRelatorios" text="Relatórios" onAction="#abrirRelatorios" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2c-chart-bar" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Region fx:id="separadorRelatorios" styleClass="sidebar-divider" prefHeight="1" maxWidth="Infinity"/>
                    <Label fx:id="lblSecaoSistema" text="SISTEMA" styleClass="sidebar-section"/>
                    <Button fx:id="btnUsuarios" text="Usuários" onAction="#abrirUsuarios" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2a-account-cog" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>
                    <Button fx:id="btnConfiguracoes" text="Configurações" onAction="#abrirConfiguracoes" maxWidth="Infinity" styleClass="sidebar-btn">
                        <graphic><StackPane styleClass="sidebar-icon-wrap"><FontIcon iconLiteral="mdi2c-cog" iconSize="16" styleClass="sidebar-icon"/></StackPane></graphic>
                    </Button>

                    <Region styleClass="sidebar-divider" prefHeight="1" maxWidth="Infinity"/>
                    <VBox styleClass="sidebar-user-area" spacing="3" alignment="CENTER_LEFT">
                        <Label fx:id="lblAvatarSidebar" styleClass="sidebar-user-avatar" text="?"/>
                        <Label fx:id="lblNomeSidebar"   styleClass="sidebar-user-nome"   text=""/>
                        <Label fx:id="lblPerfilSidebar" styleClass="sidebar-user-perfil" text=""/>
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- Área de conteúdo -->
            <StackPane fx:id="conteudoPane" styleClass="content-area">
                <Label text="Selecione um módulo no menu lateral"
                       styleClass="content-placeholder"/>
            </StackPane>

        </SplitPane>
    </center>

    <!-- Statusbar -->
    <bottom>
        <HBox styleClass="statusbar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="0" right="16" bottom="0" left="16"/></padding>
            <Label fx:id="lblStatus" text="Pronto"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblDataHora" styleClass=""/>
        </HBox>
    </bottom>

</BorderPane>
