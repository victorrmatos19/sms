<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:id="dashboardVendas"
      fx:controller="com.erp.controller.DashboardVendasController"
      styleClass="dashboard-root"
      spacing="24">
    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

    <!-- Cabeçalho -->
    <VBox spacing="4">
        <Label text="Dashboard" styleClass="page-title"/>
        <Label text="Visão geral do mês — Vendas" styleClass="page-subtitle"/>
    </VBox>

    <!-- Métricas -->
    <HBox spacing="16">
        <VBox fx:id="cardOrcamentosAbertos" styleClass="metric-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" spacing="6">
            <Label text="ORÇAMENTOS — MÊS" styleClass="metric-card-label"/>
            <Label fx:id="lblOrcamentosMes" text="0" styleClass="metric-card-value"/>
            <Label fx:id="lblValorOrcamentos" text="R$ 0,00" styleClass="metric-card-subtitle"/>
            <Label text="em breve" styleClass="badge-neutral"/>
        </VBox>

        <VBox fx:id="cardMinhasVendas" styleClass="metric-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" spacing="6">
            <Label text="VENDAS REALIZADAS — MÊS" styleClass="metric-card-label"/>
            <Label fx:id="lblVendasMes" text="0" styleClass="metric-card-value"/>
            <Label fx:id="lblValorVendas" text="R$ 0,00" styleClass="metric-card-subtitle"/>
            <Label text="em breve" styleClass="badge-neutral"/>
        </VBox>

        <VBox fx:id="cardMeta" styleClass="metric-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" spacing="6">
            <Label text="COMPRAS CONFIRMADAS — MÊS" styleClass="metric-card-label"/>
            <Label fx:id="lblComprasMes" text="0" styleClass="metric-card-value"/>
            <Label fx:id="lblValorCompras" text="R$ 0,00" styleClass="metric-card-subtitle"/>
        </VBox>
    </HBox>

    <!-- Aviso módulos em breve -->
    <VBox styleClass="dashboard-info-card" spacing="8" alignment="CENTER">
        <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>
        <Label text="🚧  Módulo de Vendas em desenvolvimento" styleClass="dashboard-info-title"/>
        <Label text="Os módulos de Orçamentos e Vendas estão previstos para a Fase 1 do sistema."
               styleClass="dashboard-info-subtitle" wrapText="true" textAlignment="CENTER"/>
    </VBox>

</VBox>
